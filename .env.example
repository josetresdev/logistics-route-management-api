# Django Settings
DEBUG=True
SECRET_KEY=super-secret-key-change-this-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=logistics
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=logistics

# Server Configuration
SERVER_PORT=8000
SERVER_HOST=0.0.0.0

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings
EMAIL_HOST_PASSWORD=your-app-password

# Third-party Services
SENTRY_DSN=

# Application-specific
MAX_UPLOAD_FILE_SIZE=10485760  # 10MB in bytes
