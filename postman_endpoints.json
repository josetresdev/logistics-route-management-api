      "name": "Authentication",
      "item": [
        {
          "name": "Obtain Auth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data && jsonData.data.token) {",
                  "        pm.environment.set('auth_token', jsonData.data.token);",
                  "        console.log('Token guardado: ' + jsonData.data.token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/token-auth/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "token-auth",
                ""
              ]
            }
          },
          "response": [
            {
              "name": "Success - New Standard Response",
              "originalRequest": {},
              "status": "200 OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Autenticación exitosa\",\n  \"data\": {\n    \"token\": \"a87bfff52d62d13e501e8cbaf787dc5e5fcbeeb3\",\n    \"user\": {\n      \"id\": 1,\n      \"username\": \"admin\",\n      \"email\": \"admin@example.com\"\n    }\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-03-01T03:08:50.000Z\",\n    \"version\": \"v1\"\n  }\n}"
            }
          ]
        }
